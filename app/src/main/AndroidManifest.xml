<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Permiso de acceso a Internet -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".util.MiApp"
        android:networkSecurityConfig="@xml/network_security_config"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Wawakusi">

        <!-- SplashActivity como la actividad principal -->
        <activity
            android:name=".view.ui.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- El resto de las actividades -->
        <activity
            android:name=".view.ui.RegistroActivity"
            android:exported="true" />
        <activity
            android:name=".view.ui.LoginActivity"
            android:exported="true" />
        <activity
            android:name=".view.ui.TiendaActivity"
            android:exported="true" />
        <activity
            android:name=".view.ui.PromocionesActivity"
            android:exported="true" />
        <activity
            android:name=".view.ui.NosotrosActivity"
            android:exported="true" />
        <activity
            android:name=".view.ui.ContactoActivity"
            android:exported="true" />

        <!-- MainActivity ahora no es la principal, pero aún se puede acceder -->
        <activity
            android:name=".view.ui.MainActivity"
            android:exported="true" />
    </application>

</manifest>